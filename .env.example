# Required for LLM reasoning.
KEEL_LLM_API_KEY=

# Required for live source research.
KEEL_WEB_SEARCH_API_KEY=
KEEL_WEB_SEARCH_PROVIDER=brave

# OpenAI defaults. Override these only when needed.
KEEL_LLM_BASE_URL=https://api.openai.com/v1
KEEL_LLM_MODEL=gpt-5.6-luna
KEEL_LLM_HTTP_REFERER=
KEEL_LLM_APP_TITLE=Keel

# Phase 1 targets test Wikipedia, never production Wikipedia.
KEEL_WIKI_API_BASE=https://test.wikipedia.org/w/api.php
KEEL_WIKI_OAUTH_TOKEN=

# Local durable state.
KEEL_SQLITE_PATH=keel.db

# Extensive OpenTelemetry tracing exported to Langfuse.
KEEL_OBSERVABILITY_BACKEND=langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development
