# Required for LLM reasoning.
KEEL_LLM_API_KEY=

# Required for live source research. LLM Context is primary; Web Search with extra
# snippets is the automatic fallback. Direct page fetches enrich up to three promising
# high-reliability sources.
KEEL_WEB_SEARCH_API_KEY=
KEEL_WEB_SEARCH_PROVIDER=brave
KEEL_WEB_SEARCH_MODE=llm_context
KEEL_WEB_CONTEXT_MAX_URLS=10
KEEL_WEB_CONTEXT_MAX_TOKENS=8192
KEEL_WEB_CONTEXT_MAX_TOKENS_PER_URL=1024
KEEL_WEB_CONTEXT_MAX_SNIPPETS=30
KEEL_WEB_CONTEXT_MAX_SNIPPETS_PER_URL=3
KEEL_WEB_CONTEXT_THRESHOLD=strict
KEEL_WEB_FETCH_FALLBACK_MAX_URLS=3

# OpenAI defaults. Override these only when needed.
KEEL_LLM_BASE_URL=https://api.openai.com/v1
KEEL_LLM_MODEL=gpt-5.6-luna
KEEL_LLM_HTTP_REFERER=
KEEL_LLM_APP_TITLE=Keel

# Phase 1 targets test Wikipedia, never production Wikipedia.
KEEL_WIKI_API_BASE=https://test.wikipedia.org/w/api.php
KEEL_WIKI_OAUTH_TOKEN=

# Local durable state.
KEEL_SQLITE_PATH=keel.db

# Extensive OpenTelemetry tracing exported to Langfuse.
KEEL_OBSERVABILITY_BACKEND=langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development
